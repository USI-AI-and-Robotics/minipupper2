  #!/usr/bin/env python3
  # Usage:
  #   python3 python_api_test_single_servo.py --servo 1
  #   python3 python_api_test_single_servo.py --servo 1 --delta 60 --hold 0.75
  #   python3 python_api_test_single_servo.py
  #
  # From any directory:
  #   python3 /home/ubuntu/mini_pupper_bsp/demos/python_api_test_single_servo.py --servo 1
  #   change servo number to 1 thru 12
  #   python3 /home/ubuntu/mini_pupper_bsp/demos/python_api_test_single_servo.py
  #
  # Servo IDs:
  #   1-3   front-right  (abduction, hip, knee)
  #   4-6   front-left   (abduction, hip, knee)
  #   7-9   back-right   (abduction, hip, knee)
  #   10-12 back-left    (abduction, hip, knee)
  #
  # Start with a small --delta and test one servo at a time.
  import argparse
  import sys
  import time

  from MangDang.mini_pupper.ESP32Interface import ESP32Interface


  NEUTRAL_POSITION = 512
  SERVO_MIN = 0
  SERVO_MAX = 1023
  SERVO_COUNT = 12
  DEFAULT_DELTA = 60
  DEFAULT_HOLD_SECONDS = 0.75

  LEG_NAMES = ["front-right", "front-left", "back-right", "back-left"]
  JOINT_NAMES = ["abduction", "hip", "knee"]


  def clamp(value, low, high):
      return max(low, min(high, value))


  def servo_label(servo_id):
      zero_based = servo_id - 1
      leg_index = zero_based // 3
      joint_index = zero_based % 3
      return f"servo {servo_id}: {JOINT_NAMES[joint_index]} {LEG_NAMES[leg_index]}"


  def make_positions():
      return [NEUTRAL_POSITION] * SERVO_COUNT


  def make_torque(active_servo_id):
      torque = [0] * SERVO_COUNT
      torque[active_servo_id - 1] = 1
      return torque


  def move_servo(esp32, servo_id, delta, hold_seconds):
      index = servo_id - 1
      torque = make_torque(servo_id)
      positions = make_positions()

      low_position = clamp(NEUTRAL_POSITION - delta, SERVO_MIN, SERVO_MAX)
      high_position = clamp(NEUTRAL_POSITION + delta, SERVO_MIN, SERVO_MAX)

      sequence = [
          ("neutral", NEUTRAL_POSITION),
          ("low", low_position),
          ("neutral", NEUTRAL_POSITION),
          ("high", high_position),
          ("neutral", NEUTRAL_POSITION),
      ]

      print(f"Testing {servo_label(servo_id)}")
      for step_name, target in sequence:
          positions[index] = target
          print(f"  {step_name:>7}: position={target}")
          esp32.servos_set_position_torque(positions, torque)
          time.sleep(hold_seconds)

      # Release all servos after the test step completes.
      esp32.servos_set_position_torque(make_positions(), [0] * SERVO_COUNT)


  def parse_args():
      parser = argparse.ArgumentParser(
          description="Test one Mini Pupper servo at a time."
      )
      parser.add_argument(
          "--servo",
          type=int,
          help="Servo to test, from 1 to 12. If omitted, all servos are tested in order.",
      )
      parser.add_argument(
          "--delta",
          type=int,
          default=DEFAULT_DELTA,
          help=f"Distance from neutral position {NEUTRAL_POSITION}. Default: {DEFAULT_DELTA}.",
      )
      parser.add_argument(
          "--hold",
          type=float,
          default=DEFAULT_HOLD_SECONDS,
          help=f"Seconds to hold each step. Default: {DEFAULT_HOLD_SECONDS}.",
      )
      return parser.parse_args()


  def main():
      args = parse_args()

      if args.servo is not None and not 1 <= args.servo <= SERVO_COUNT:
          print("--servo must be between 1 and 12", file=sys.stderr)
          return 2

      if args.delta < 0:
          print("--delta must be non-negative", file=sys.stderr)
          return 2

      if args.hold <= 0:
          print("--hold must be greater than 0", file=sys.stderr)
          return 2

      servos = [args.servo] if args.servo is not None else list(range(1, SERVO_COUNT + 1))

      esp32 = ESP32Interface()
      try:
          for servo_id in servos:
              move_servo(esp32, servo_id, args.delta, args.hold)
              time.sleep(0.5)
      finally:
          esp32.servos_set_position_torque(make_positions(), [0] * SERVO_COUNT)
          esp32.close()

      return 0


  if __name__ == "__main__":
      raise SystemExit(main())

